# Generate with:  docker compose run --rm --entrypoint /daans-cat daans-cat hash
# (or:  go run . hash)
# Do not forget the single quotes, the hash contains $ characters.
ADMIN_PASSWORD_HASH='$2a$12$replace.me.with.a.real.bcrypt.hash'

# Canonical origin. Used for RSS links and to decide on secure cookies.
SITE_URL=https://daans.cat

SITE_TITLE=daans.cat

# Used for <meta description>, Open Graph, and the RSS channel description.
SITE_DESC=pictures of daan's cat

# /security.txt and /.well-known/security.txt 301 here. Empty = 404 instead.
SECURITY_TXT_URL=https://dnbr.cloud/.well-known/security.txt

# Set to true when a reverse proxy sits in front (it does, in the setup below).
# This makes the rate limiter read X-Forwarded-For.
BEHIND_PROXY=true

# auto = secure cookies whenever SITE_URL is https. Leave it alone.
SECURE_COOKIES=auto

ADDR=:8080
DATA_DIR=/data
